LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
MODEL_NAME=qwen2.5-7b-instruct
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Alternative:
# EMBEDDING_MODEL=BAAI/bge-small-en
EMBEDDING_CACHE_PATH=data/models
EMBEDDING_ALLOW_DOWNLOAD=true

VOICE_STT_PROVIDER=faster_whisper
VOICE_TTS_PROVIDER=coqui
# VOICE_TTS_PROVIDER=edge
WHISPER_MODEL_SIZE=small
WHISPER_COMPUTE_TYPE=int8
TTS_MODEL_NAME=tts_models/en/ljspeech/tacotron2-DDC
VOICE_OUTPUT_DIR=data/voice/output
AUDIO_UPLOAD_DIR=data/voice/uploads
EDGE_TTS_VOICE=en-US-AriaNeural
COQUI_SPEAKER=
COQUI_LANGUAGE=
VOICE_OUTPUT_FORMAT=mp3
VOICE_INCLUDE_REFLECTION_DEFAULT=true
VOICE_FILE_TTL_HOURS=24
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

DATABASE_URL=postgresql+psycopg://boran:boranpass@127.0.0.1:5432/boran_ai
JWT_SECRET_KEY=change-this-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

AUTO_CONSOLIDATION_ENABLED=true
CONSOLIDATION_INTERVAL_SECONDS=300
CONSOLIDATION_MIN_NEW_ITEMS=8
