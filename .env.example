LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
MODEL_NAME=qwen2.5-7b-instruct
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Alternative:
# EMBEDDING_MODEL=BAAI/bge-small-en
EMBEDDING_CACHE_PATH=data/models
EMBEDDING_ALLOW_DOWNLOAD=true
UPLOAD_MAX_FILE_SIZE_MB=100

VOICE_STT_PROVIDER=faster_whisper
VOICE_TTS_PROVIDER=edge
# Optional local provider:
# VOICE_TTS_PROVIDER=coqui
WHISPER_MODEL_SIZE=base
WHISPER_DEFAULT_LANGUAGE=tr
WHISPER_BEAM_SIZE=1
WHISPER_BEST_OF=1
WHISPER_VAD_FILTER=false
WHISPER_COMPUTE_TYPE=int8
TTS_MODEL_NAME=tts_models/en/ljspeech/tacotron2-DDC
VOICE_OUTPUT_DIR=data/voice/output
AUDIO_UPLOAD_DIR=data/voice/uploads
EDGE_TTS_VOICE=auto
EDGE_TTS_VOICE_PROFILE=female
EDGE_TTS_VOICE_FEMALE=tr-TR-EmelNeural
EDGE_TTS_VOICE_MALE=tr-TR-AhmetNeural
EDGE_TTS_RATE=-5%
EDGE_TTS_PITCH=+0Hz
COQUI_SPEAKER=
COQUI_LANGUAGE=
VOICE_OUTPUT_FORMAT=mp3
VOICE_TTS_MAX_CHARS=700
VOICE_WARMUP_ENABLED=true
VOICE_INCLUDE_REFLECTION_DEFAULT=true
VOICE_FILE_TTL_HOURS=24
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=true
# Frontend mobile/LAN note:
# Set frontend/.env VITE_API_BASE_URL to http://<PC_LAN_IP>:8000
# or leave it empty to auto-use the current browser host on port 8000.

DATABASE_URL=postgresql+psycopg://boran:boranpass@127.0.0.1:5432/boran_ai
JWT_SECRET_KEY=change-this-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
# Comma-separated list. Match by external_id, username, or email.
# Example: ADMIN_IDENTIFIERS=admin,admin@example.com,user_abc123
ADMIN_IDENTIFIERS=

AUTO_CONSOLIDATION_ENABLED=true
CONSOLIDATION_INTERVAL_SECONDS=300
CONSOLIDATION_MIN_NEW_ITEMS=8
SEMANTIC_LINK_THRESHOLD=0.82
GRAPH_CO_OCCURRENCE_WINDOW=4
CLUSTER_MIN_SIZE=2
MEMORY_DECAY_DAYS=30
MEMORY_IMPORTANCE_DEFAULT=1.0
CHAT_DOC_CONTEXT_LIMIT=2
CHAT_CONVERSATION_CONTEXT_LIMIT=2
CHAT_CORRECTION_CONTEXT_LIMIT=1
CHAT_LONG_TERM_CONTEXT_LIMIT=2
CHAT_CLUSTER_CONTEXT_LIMIT=2
CHAT_SEMANTIC_CONTEXT_LIMIT=2
CHAT_GRAPH_CONTEXT_LIMIT=3
CHAT_MAX_CONTEXT_CHARS=3200
RAG_PER_SOURCE_CAP_MIN=2
RAG_PER_SOURCE_CAP_MAX=4
