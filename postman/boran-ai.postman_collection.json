            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"message\": \"Tragna metninde majikal piramitler neden onemli?\",\n  \"save_to_long_term\": true\n}"
        },
        "url": {
          "raw": "{{base_url}}/chat",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "chat"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test(\"Reply exists\", function () {",
              "  pm.expect(json.reply).to.be.a(\"string\");",
              "});"
            ]
          }
        }
      ]
    },
