# Leave empty to auto-resolve backend as http(s)://<current-browser-host>:8000
# (recommended for LAN/mobile access from phone)
VITE_API_BASE_URL=
# Optional explicit override:
# VITE_API_BASE_URL=http://<PC_LAN_IP>:8000
VITE_MAX_UPLOAD_SIZE_MB=100

# Optional PWA labels (for future UI usage)
VITE_PWA_APP_NAME=boran.ai
VITE_PWA_THEME_COLOR=#0f172a
VITE_PWA_BACKGROUND_COLOR=#0f172a
